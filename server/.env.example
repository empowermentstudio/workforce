# ── Church Info ───────────────────────────────────────────────
CHURCH_NAME=Grace Community Church

# ── Resend (Email) ────────────────────────────────────────────
# Sign up free at https://resend.com → API Keys → Create key
# Free tier: 3,000 emails/month
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# The "from" address — must be a verified domain in Resend
# For testing you can use: onboarding@resend.dev
EMAIL_FROM=reminders@gracechurch.org

# ── Twilio (SMS) ──────────────────────────────────────────────
# Sign up at https://twilio.com → Console → Account Info
# Free trial: ~$15 credit ≈ 1,900 SMS messages (~$0.0079/SMS)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE=+19725550200

# ── Reminder Schedule ─────────────────────────────────────────
# How many days before a task to send the advance reminder
REMINDER_DAYS_AHEAD=3

# ── Server ────────────────────────────────────────────────────
PORT=3001
